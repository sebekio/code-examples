{
  "name": "code-examples",
  // In the multi-repo workspace, Python is already available from the workspace
  // container (/usr/bin/python3). This devcontainer.json only adds VS Code config.
  // If opened standalone in Codespaces, the image below provides Python.
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "editor.rulers": [88]
      }
    }
  }
}
